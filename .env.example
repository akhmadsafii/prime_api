PORT=4000
WEB_ORIGIN=http://localhost:3000
# Existing Prime connection. DB_AUTO_* may be supplied when the reporting
# tables live on a separate server; when omitted the API reuses DB_*.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=prime_user
DB_PASSWORD=replace-me
DB_DATABASE=prime
DB_AUTO_HOST=
DB_AUTO_PORT=
DB_AUTO_USERNAME=
DB_AUTO_PASSWORD=
DB_AUTO_DATABASE=
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DATABASE=dashboard
REDIS_URL=redis://localhost:6379
JWT_SECRET=replace-with-a-long-random-secret
